---
import { PortableText as PortableTextInternal } from 'astro-portabletext';
import PortableTextImage from "./PortableTextImage.astro";

const { portableText } = Astro.props;

// Connect custom PortableText schema elements (like custom images) to Astro components
const components = {
  type: {
    image: PortableTextImage,
  }
};
---

<div class="rich-text-content">
  <PortableTextInternal value={portableText} components={components} />
</div>

<style is:global>
  .rich-text-content p {
    font-size: 1.125rem;
    line-height: 1.7;
    margin-bottom: 1.5rem;
    color: var(--neutral--light-gray);
  }
  .rich-text-content h2,
  .rich-text-content h3,
  .rich-text-content h4 {
    color: var(--brand--heading);
    font-weight: 600;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    letter-spacing: -0.02em;
  }
  .rich-text-content h2 { font-size: 1.875rem; }
  .rich-text-content h3 { font-size: 1.5rem; }
  .rich-text-content blockquote {
    border-left: 4px solid var(--neutral--primary-blue);
    padding-left: 1.5rem;
    margin: 2rem 0;
    font-style: italic;
    color: var(--neutral--dark);
  }
</style>